APP_NAME=SM Racing API
ENVIRONMENT=development
# Neon is the canonical database source for this project.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@NEON_HOST/DB?sslmode=require&channel_binding=require
# JWT_SECRET_KEY must be a long random secret in production and non-test environments.
JWT_SECRET_KEY=generate-a-long-random-64-character-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
MAKE_WEBHOOK_URL=
CHATBOT_NLP_ENABLED=false
# Enable OCR image analysis for setup sheets and handwritten notes.
CHATBOT_IMAGE_ANALYSIS_ENABLED=true
# Store real keys only in your local .env or hosting provider environment variables. Never commit secrets.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
# Optional ISO-639-1 hint for voice transcription, for example en.
OPENAI_TRANSCRIPTION_LANGUAGE=
# GPT-5.4 is the production OCR model for the OCR Notes extraction workflow.
OPENAI_VISION_MODEL=gpt-5.4
# Optional fallback model if the primary OCR model is temporarily unavailable.
OPENAI_FALLBACK_MODEL=gpt-5.5
OPENAI_REQUEST_TIMEOUT_SECONDS=8
OPENAI_INTENT_CONFIDENCE_THRESHOLD=0.70
# Optional: allow all Vercel preview and production deployments.
# CORS_ORIGIN_REGEX=^https://.*\.vercel\.app$
